{
  "name": "@fairaccess/root",
  "version": "0.0.1",
  "description": "Your device. Your choice. Your terms.",
  "type": "module",
  "private": true,
  "author": "Robin Bühler",
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/**/*",
    "libs/**/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --log-order stream",
    "upgrade": "ncu -i -w && bun install",
    "lint": "biome lint",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "tag": "changeset tag",
    "test:e2e": "turbo run test:e2e",
    "test": "turbo run test",
    "version": "changeset version && bun install",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "^1.3.9",
    "npm-check-updates": "^19.3.2",
    "turbo": "^2.8.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
