{
  "name": "@fairaccess/root",
  "version": "0.0.1",
  "description": "Your device. Your choice. Your terms.",
  "type": "module",
  "private": true,
  "author": "Robin Bühler",
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/**/*",
    "libs/**/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo watch dev",
    "upgrade": "ncu -i -w && bun install",
    "lint": "biome lint",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "tag": "changeset tag",
    "test:e2e": "turbo run test:e2e",
    "test": "turbo run test",
    "version": "changeset version && bun install",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "^2.31.0",
    "@iconify-json/tabler": "^1.2.33",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "npm-check-updates": "^21.0.3",
    "turbo": "^2.9.6",
    "unplugin-icons": "^23.0.1"
  },
  "peerDependencies": {
    "typescript": "^6"
  }
}
