{
  "name": "@fairaccess/core",
  "private": true,
  "version": "0.0.59",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev --host",
    "build": "bun --bun vite build && bun build scripts/migrate.ts --outfile dist/migrate.js --target bun",
    "preview": "bun --bun vite preview",
    "db:migrate": "bun run scripts/migrate.ts",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:e2e": "playwright test",
    "test": "bun run test:e2e"
  },
  "dependencies": {
    "@fairaccess/auth": "workspace:*",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@fairaccess/db": "workspace:*",
    "@fairaccess/i18n": "workspace:*",
    "@fairaccess/theme": "workspace:*",
    "@iconify-json/tabler": "^1.2.29",
    "@playwright/test": "^1.58.2",
    "@poppanator/sveltekit-svg": "^6.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.53.7",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.4",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0"
  }
}
